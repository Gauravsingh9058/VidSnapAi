SECRET_KEY=change-this-in-production
DATABASE_URL=sqlite:///instance/vidsnapai.db
MAX_CONTENT_LENGTH=209715200
SCHEDULER_POLL_INTERVAL_SECONDS=30
MAX_SOCIAL_ACCOUNTS_PER_USER=10
LIFETIME_PLAN_PRICE_INR=399
LIFETIME_PLAN_CURRENCY=INR
APP_BASE_URL=http://127.0.0.1:5000
UPLOAD_ROOT=app/uploads
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=replace-with-your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=replace-with-your-webhook-secret
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=vidsnapai
# Use the numeric App ID from Meta App Dashboard > App Settings > Basic.
META_APP_ID=your-meta-app-id
# Use the App Secret from Meta App Dashboard > App Settings > Basic, not a user/page access token.
META_APP_SECRET=your-meta-app-secret
# Optional: leave blank to derive the callback from APP_BASE_URL.
META_REDIRECT_URI=
META_API_VERSION=v23.0
SOCIAL_TOKEN_ENCRYPTION_SECRET=change-this-to-a-long-random-secret
FREE_EXPORT_WATERMARK_TEXT=VidSnapAI Free
FFMPEG_FONT_PATH=
